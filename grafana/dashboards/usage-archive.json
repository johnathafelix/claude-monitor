{
  "annotations": { "list": [] },
  "description": "Usage served from the MongoDB archive (usage-archive service). Ingests ALL ~/.claude transcript data — including subagents — every minute, so history survives Claude Code's ~30-day retention. Costs are computed from dated LiteLLM pricing snapshots: past usage keeps the price in effect at the time.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Claude Code Live (OTel)",
      "type": "link",
      "url": "/d/claude-otel",
      "icon": "dashboard"
    },
    {
      "title": "Claude Code Stats (ccusage)",
      "type": "link",
      "url": "/d/ccusage-stats",
      "icon": "dashboard"
    }
  ],
  "liveNow": true,
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-usage-archive" },
        "definition": "usage-archive model names",
        "query": {
          "queryType": "infinity",
          "infinityQuery": {
            "refId": "variable",
            "type": "json",
            "source": "url",
            "format": "table",
            "url": "http://usage-archive:3002/model-names",
            "url_options": { "method": "GET" },
            "root_selector": "",
            "columns": [{ "selector": ".", "text": "model", "type": "string" }]
          }
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": "all",
        "multi": false,
        "current": { "text": "All", "value": "$__all", "selected": true },
        "options": [],
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 13,
      "type": "gauge",
      "title": "Burn Rate (tokens/min)",
      "description": "Rolling 1-hour average token rate across the selected model(s). Independent of the dashboard time range.",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-usage-archive" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-usage-archive" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://usage-archive:3002/burnrate?model=${model}",
          "url_options": { "method": "GET" },
          "root_selector": "",
          "columns": [{ "selector": "tokensPerMinute", "text": "tokens/min", "type": "number" }]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1000000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300000 },
              { "color": "red", "value": 700000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 14,
      "type": "gauge",
      "title": "Cost / hour",
      "description": "Spend over the last rolling hour across the selected model(s). Independent of the dashboard time range.",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-usage-archive" },
      "targets": [
        {
