        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
