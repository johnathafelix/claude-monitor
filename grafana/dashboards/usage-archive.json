          "url": "http://usage-archive:3002/burnrate?model=${model}",
          "url_options": { "method": "GET" },
          "root_selector": "",
          "columns": [{ "selector": "costPerHour", "text": "$/hour", "type": "number" }]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
