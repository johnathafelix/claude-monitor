        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Output Tokens",
      "gridPos": { "h": 6, "w": 5, "x": 10, "y": 0 },
