{
  "annotations": {
    "list": []
  },
  "description": "Live per-model usage from Claude Code's built-in OpenTelemetry export. Includes background/auxiliary calls (e.g. the auto-mode classifier) that never appear in the transcript logs. Only records sessions started after telemetry was enabled — for history, see the ccusage dashboard. Totals are cumulative per session, summed over sessions that reported within the selected range.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Claude Code Stats (ccusage)",
      "type": "link",
      "url": "/d/ccusage-stats",
      "icon": "dashboard"
    }
