      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "basic",
        "showUnfilled": true
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Token Throughput by Model (tokens/min)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
