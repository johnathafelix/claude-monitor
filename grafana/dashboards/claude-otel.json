{
  "annotations": { "list": [] },
  "description": "Live per-model usage from Claude Code's built-in OpenTelemetry export. Includes background/auxiliary calls (e.g. the auto-mode classifier) that never appear in the transcript logs. Only records sessions started after telemetry was enabled — for history, see the ccusage dashboard.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Claude Code Stats (ccusage)",
      "type": "link",
      "url": "/d/ccusage-stats",
      "icon": "dashboard"
    }
  ],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Tokens",
      "gridPos": { "h": 6, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_token_usage_tokens_total[$__range]))",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Input Tokens",
      "gridPos": { "h": 6, "w": 5, "x": 5, "y": 0 },
