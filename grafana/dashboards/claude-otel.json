    {
      "id": 5,
      "type": "stat",
      "title": "Total Cost",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Tokens by Model",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token Throughput by Type (tokens/min)",
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[$__rate_interval]) * 60)",
          "legendFormat": "{{type}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Tokens by Source (main / subagent / auxiliary)",
      "description": "auxiliary = background calls such as the auto-mode classifier — the usage the transcript logs (and ccusage) never see.",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (query_source) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{query_source}}",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calc": "lastNotNull", "fields": "", "values": false },
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Usage by Model × Type",
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model, type) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": {},
            "renameByName": {}
          }
        },
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "type",
            "rowField": "model",
            "valueField": "Value"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "align": "auto" },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Cost by Model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
